# Copy to .env; it is loaded automatically (python-dotenv). Exported
# environment variables take precedence over .env values.

# --- Claude / TrueFoundry gateway ---
# All Anthropic calls go through the gateway when TF_GATEWAY_URL is set
# (Anthropic-compatible endpoint + TF virtual key); direct API otherwise.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
TF_GATEWAY_URL=
TF_API_KEY=

# --- Demo / testing switches ---
CHATPCB_MOCK_LLM=0          # 1 = canned spec, no API key needed
CHATPCB_FAIL_STAGE=         # e.g. "layout" to demo the retry/partial path
CHATPCB_MAX_STAGE_ATTEMPTS=3
CHATPCB_MAX_SPEC_REVISIONS=3
CHATPCB_ARTIFACTS_DIR=      # default: ./artifacts

# --- Telemetry (ClickHouse; JSONL fallback when unset) ---
CLICKHOUSE_URL=             # clickhouse://user:pass@host:8443/db?secure=true

# --- Export (S3 presigned URLs; local /artifacts URLs when unset) ---
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Heavy routing worker (Redis queue; inline layout when unset) ---
REDIS_URL=
CHATPCB_REMOTE_LAYOUT=0
CHATPCB_LAYOUT_TIMEOUT_S=300

# --- Integrations ---
JUA_API_KEY=                # weather/climate notes for outdoor designs (stubbed)

# Composio (share button: GitHub repo + Gmail summary; skipped when unset)
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default
COMPOSIO_GITHUB_OWNER=      # GitHub login that owns the created repo
COMPOSIO_GMAIL_TO=          # recipient; unset = no email

# Senso knowledge layer (local docs/pcbway_capabilities.md fallback when unset)
SENSO_API_KEY=
SENSO_BASE_URL=

# Guild.ai experiment tracking (JSONL fallback to artifacts/experiments.jsonl)
CHATPCB_PROMPT_VERSION=dev  # label recorded alongside the prompt content hash

# Airbyte LCSC parts sync (CSV fallback when unset; see airbyte/README.md)
AIRBYTE_API_URL=
AIRBYTE_CONNECTION_ID=
AIRBYTE_API_TOKEN=
PARTS_DB_URL=               # e.g. sqlite:///data/parts.db or postgresql://...
